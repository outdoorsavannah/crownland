{
  "name": "bc-crownland-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Offline-first BC Crown Land map (Capacitor, iOS + Android)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "gen:sample": "node scripts/gen-sample-data.mjs",
    "test": "node scripts/test-resume.mjs && node scripts/test-height.mjs && node scripts/test-bigtree-score.mjs && node scripts/test-nearest-town.mjs",
    "cap:sync": "cap sync",
    "cap:ios": "cap open ios",
    "cap:android": "cap open android"
  },
  "dependencies": {
    "@capacitor-community/camera-preview": "^6.0.1",
    "@capacitor/android": "^6.1.2",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/core": "^6.1.2",
    "@capacitor/filesystem": "^6.0.1",
    "@capacitor/geolocation": "^6.0.1",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/motion": "^6.0.2",
    "@capacitor/network": "^6.0.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/share": "^6.0.4",
    "maplibre-gl": "^4.7.1",
    "pmtiles": "^3.2.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
