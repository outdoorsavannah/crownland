# Copy to `.env` and set to your Cloudflare R2 public base URL (must end with /).
# The app fetches ${VITE_MANIFEST_BASE_URL}manifest.json and downloads packs from
# the same base. Use a custom domain bound to the bucket for production; the
# r2.dev URL works for testing but is rate-limited.
#
# Custom domain example:
#   VITE_MANIFEST_BASE_URL=https://data.yourdomain.com/crownland/
# r2.dev example:
#   VITE_MANIFEST_BASE_URL=https://pub-<hash>.r2.dev/
VITE_MANIFEST_BASE_URL=https://REPLACE-ME.r2.dev/
